    <!-- Physical Sensor Icon -->
    <mxCell id="sensor" value="🔧 Wellhead Sensor&#xa;Device ID: wellhead-TX-001&#xa;&#xa;• Pressure Sensor (PSI)&#xa;• Temperature Sensor (°F)&#xa;• Flow Rate Sensor (BPD)&#xa;&#xa;Sends data every 5 seconds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
