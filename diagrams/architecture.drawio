    </mxCell>

    <!-- Arrow: SCADA to DMZ (going right) -->
    <mxCell id="arrow_scada_dmz" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#FF0000;strokeWidth=3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="scada" target="dmz">
      <mxGeometry relative="1" as="geometry" />
