    <!-- IoT Hub -->
    <mxCell id="iothub" value="🌐 Azure IoT Hub&#xa;iothub-crescent-ot-poc&#xa;&#xa;• Secure device authentication&#xa;• 400K messages/day (S1 tier)&#xa;• THE crossing point OT→IT&#xa;• Device registry&#xa;• Message routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="750" y="160" width="220" height="150" as="geometry" />
