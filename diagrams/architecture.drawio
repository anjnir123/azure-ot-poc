    <!-- ================================ -->
    <mxCell id="ot_box" value="OT NETWORK&#xa;(Air-Gapped / Isolated)" style="swimlane;startSize=50;fillColor=#FFE6CC;strokeColor=#d6b656;strokeWidth=3;fontStyle=1;fontSize=14;fontColor=#7d4e00;" vertex="1" parent="1">
      <mxGeometry x="40" y="100" width="340" height="600" as="geometry" />
