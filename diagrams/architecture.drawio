      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Stream Analytics -->
    <mxCell id="streamanalytics" value="⚡ Azure Stream Analytics&#xa;sa-crescent-ot-poc&#xa;&#xa;• Reads real-time from IoT Hub&#xa;• SQL-like query on live stream&#xa;• Calculates 1-min averages&#xa;• Detects pressure &gt; 2700 PSI&#xa;• Routes to 2 outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="1050" y="160" width="230" height="150" as="geometry" />
