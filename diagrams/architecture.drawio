    <!-- SCADA Server -->
    <mxCell id="scada" value="🖥️ SCADA / Historian Server&#xa;(On-Premises OT Network)&#xa;&#xa;• OSIsoft PI Historian&#xa;• Aggregates sensor readings&#xa;• Runs on isolated network&#xa;• NO internet access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
