    </mxCell>

    <!-- ONE WAY ARROW label -->
    <mxCell id="oneway_label" value="⬅️ NO RETURN PATH&#xa;Segregation enforced at&#xa;network/firewall level" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="430" y="560" width="220" height="60" as="geometry" />
    </mxCell>

    <!-- ================================ -->
