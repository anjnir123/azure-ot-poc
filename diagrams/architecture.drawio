    <mxCell id="azure_box" value="☁️ AZURE CLOUD — IT Network" style="swimlane;startSize=50;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=3;fontStyle=1;fontSize=14;fontColor=#1F4E79;" vertex="1" parent="1">
      <mxGeometry x="700" y="100" width="920" height="700" as="geometry" />
