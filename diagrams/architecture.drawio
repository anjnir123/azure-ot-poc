    <!-- Key Security principle box -->
    <mxCell id="principle" value="🔒 CORE SECURITY PRINCIPLE: Data flows FROM OT TO IT only. The cloud RECEIVES data but NEVER sends commands back to OT equipment. This segregation prevents a cloud breach from becoming a physical safety incident." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
