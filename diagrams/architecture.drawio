    <!-- Storage Account (Data Lake) -->
    <mxCell id="storage" value="💾 Azure Storage Account&#xa;sacrescentot2024&#xa;&#xa;Container: sensor-data&#xa;• Avg readings per minute&#xa;• Partitioned by date/time&#xa;&#xa;Container: pressure-alerts&#xa;• High pressure events only&#xa;• Instant, no windowing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
