    <mxCell id="legend1" value="→ Green arrows = Normal data flow (OT to IT, one-directional)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#006600;" vertex="1" parent="1">
      <mxGeometry x="40" y="770" width="500" height="25" as="geometry" />
