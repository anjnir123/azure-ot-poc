    </mxCell>

    <!-- Arrow: Sensor to SCADA -->
    <mxCell id="arrow_sensor_scada" value="Hardwired / OT Protocol&#xa;(Modbus, MQTT)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1" source="sensor" target="scada">
      <mxGeometry relative="1" as="geometry" />
