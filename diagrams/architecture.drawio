    <!-- ================================ -->
    <!-- DMZ / FIREWALL (MIDDLE) -->
    <!-- ================================ -->
    <mxCell id="dmz" value="🔥 FIREWALL / DMZ&#xa;&#xa;ONE-WAY DATA FLOW&#xa;&#xa;OT → IT  ✅&#xa;IT → OT  ❌&#xa;&#xa;Strict allow rules:&#xa;• Only specific OT server IP&#xa;• Only port 443 (HTTPS)&#xa;• Only to IoT Hub endpoint&#xa;&#xa;Everything else = DENIED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;fontSize=11;fontStyle=1;" vertex="1" parent="1">
