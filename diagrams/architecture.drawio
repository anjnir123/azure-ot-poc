    <!-- TITLE -->
    <mxCell id="title" value="Azure IoT/OT-to-Cloud Secure Data Pipeline — Crescent Energy POC" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
